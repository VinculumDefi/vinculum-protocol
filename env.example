# ─────────────────────────────────────────────────────────────────────────────
# Vinculum Protocol — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub — it is in .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── DEPLOYER WALLET ───────────────────────────────────────────────────────────
# Private key of the wallet used for deployment
# On mainnet this should be the Gnosis Safe owner key
DEPLOYER_PRIVATE_KEY=0x_your_private_key_here

# ── RPC URLS ──────────────────────────────────────────────────────────────────
# Base mainnet — get from Coinbase Developer Platform (free)
# https://portal.cdp.coinbase.com
BASE_RPC_URL=https://mainnet.base.org

# Base Sepolia testnet
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Ethereum mainnet — get from Alchemy or Infura (free tier available)
# https://www.alchemy.com or https://www.infura.io
ETHEREUM_RPC_URL=https://eth.llamarpc.com

# Ethereum Sepolia testnet
SEPOLIA_RPC_URL=https://rpc.sepolia.org

# BNB Chain mainnet
BNB_RPC_URL=https://bsc-dataseed.binance.org

# BNB Chain testnet
BNB_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545

# ── BLOCK EXPLORER API KEYS ───────────────────────────────────────────────────
# Required for contract verification after deployment
# Basescan: https://basescan.org/myapikey
BASESCAN_API_KEY=your_basescan_api_key

# Etherscan: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key

# BscScan: https://bscscan.com/myapikey
BSCSCAN_API_KEY=your_bscscan_api_key

# ── OPTIONAL ──────────────────────────────────────────────────────────────────
# CoinMarketCap API key for gas reporter (USD gas estimates)
# https://coinmarketcap.com/api
# CMC_API_KEY=your_cmc_api_key
