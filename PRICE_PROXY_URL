// =====================================================
// SUMMARY BAR
// =====================================================
function updateSummary() {
  document.getElementById("stat-total").textContent = ASSETS.length;
  document.getElementById("stat-active").textContent = ASSETS.filter(a => a.active).length;
  document.getElementById("stat-tier-a").textContent = ASSETS.filter(a => a.tier === "A").length;
  document.getElementById("stat-tier-b").textContent = ASSETS.filter(a => a.tier === "B").length;
  document.getElementById("stat-tier-c").textContent = ASSETS.filter(a => a.tier === "C").length;
  document.getElementById("stat-chainlink").textContent = ASSETS.filter(a => a.price_source_type === "Chainlink").length;
  document.getElementById("stat-twap").textContent = ASSETS.filter(a => a.price_source_type === "TWAP").length;
  document.getElementById("stat-tbd").textContent = ASSETS.filter(a => a.price_source_type === "TBD").length;
}

// =====================================================
// FILTER + SORT
// =====================================================
function applyFilters() {
  const q = document.getElementById("search-input").value.toLowerCase();
  const fTier = document.getElementById("filter-tier").value;
  const fCat = document.getElementById("filter-category").value;
  const fChain = document.getElementById("filter-chain").value;
  const fActive = document.getElementById("filter-active").value;
  const fSource = document.getElementById("filter-source").value;

  filtered = ASSETS.filter(a => {
    if (q) {
      const allAddrs = a.representations.map(r => r.contract_address).join(" ").toLowerCase();
      if (!a.name.toLowerCase().includes(q) && !a.symbol.toLowerCase().includes(q) && !allAddrs.includes(q)) return false;
    }
    if (fTier && a.tier !== fTier) return false;
    if (fCat && a.category !== fCat) return false;
    if (fChain && a.canonical_chain !== fChain) return false;
    if (fActive && String(a.active) !== fActive) return false;
    if (fSource && a.price_source_type !== fSource) return false;
    return true;
  });

  const sk = document.getElementById("sort-by").value;
  const sd = document.getElementById("sort-dir").value;

  filtered.sort((a, b) => {
    let av, bv;
    if (sk === "price") {
      av = priceData[a.coingecko_id]?.price ?? -1;
      bv = priceData[b.coingecko_id]?.price ?? -1;
    } else if (sk === "change24h") {
      av = priceData[a.coingecko_id]?.change24h ?? -999;
      bv = priceData[b.coingecko_id]?.change24h ?? -999;
    } else if (sk === "marketCap") {
      av = priceData[a.coingecko_id]?.marketCap ?? -1;
      bv = priceData[b.coingecko_id]?.marketCap ?? -1;
    } else if (sk === "tier") {
      av = { A:1, B:2, C:3 }[a.tier] || 9;
      bv = { A:1, B:2, C:3 }[b.tier] || 9;
    } else {
      av = (a[sk] || "").toString().toLowerCase();
      bv = (b[sk] || "").toString().toLowerCase();
    }
    if (av < bv) return sd === "asc" ? -1 : 1;
    if (av > bv) return sd === "asc" ? 1 : -1;
    return 0;
  });

  renderTable(filtered);
}

function sortBy(key) {
  document.getElementById("sort-by").value = key;
  const dir = document.getElementById("sort-dir");
  dir.value = dir.value === "asc" ? "desc" : "asc";
  applyFilters();
}

// =====================================================
// MODAL
// =====================================================
function openModal(idx) {
  // Map from filtered index back to asset
  const asset = filtered[idx];
  if (!asset) return;

  const pd = priceData[asset.coingecko_id] || {};
  const price = pd.price ?? null;
  const change = pd.change24h ?? null;
  const mcap = pd.marketCap ?? null;
  const isPlaceholder = asset.coingecko_id.startsWith("PLACEHOLDER");

  const priceStr = isPlaceholder ? "N/A" : (price !== null ? fmtPrice(price) : (fetchAttempted ? "N/A" : "Loading…"));
  const changeStr = change !== null ? fmtChange(change) : "N/A";
  const changeClass = change !== null ? (change >= 0 ? "change-pos" : "change-neg") : "change-na";

  document.getElementById("modal-content").innerHTML = `
    <div class="modal-symbol-row">
      <div class="modal-icon">${asset.symbol.slice(0,4)}</div>
      <div>
        <div class="modal-title">${asset.name}</div>
        <div class="modal-ticker">${asset.symbol} &nbsp;·&nbsp; ${tierBadge(asset.tier)} &nbsp;·&nbsp; <span class="chain-tag">${asset.category}</span></div>
      </div>
    </div>

    <div class="modal-section">
      <div class="modal-section-title">Market Data (CoinGecko — Display Only)</div>
      <div class="market-card">
        <div>
          <div class="mkt-item-label">Price (USD)</div>
          <div class="mkt-item-val">${priceStr}</div>
        </div>
        <div>
          <div class="mkt-item-label">24h Change</div>
          <div class="mkt-item-val ${changeClass}">${changeStr}</div>
        </div>
        <div>
          <div class="mkt-item-label">Market Cap</div>
          <div class="mkt-item-val">${fmtMktCap(mcap)}</div>
        </div>
        <div>
          <div class="mkt-item-label">CoinGecko ID</div>
          <div class="mkt-item-val" style="font-size:11px">${isPlaceholder ? "⚠ Placeholder" : asset.coingecko_id}</div>
        </div>
      </div>
    </div>

    <div class="modal-section">
      <div class="modal-section-title">Registry Details</div>
      <div class="modal-row"><span class="modal-key">Canonical Chain</span><span class="modal-val">${asset.canonical_chain}</span></div>
      <div class="modal-row"><span class="modal-key">Active Status</span><span class="modal-val">${asset.active ? "✅ Active" : "❌ Inactive"}</span></div>
      <div class="modal-row"><span class="modal-key">Price Source</span><span class="modal-val">${sourceBadge(asset.price_source_type)}</span></div>
      <div class="modal-row"><span class="modal-key">Oracle Risk</span><span class="modal-val"><span class="${riskClass(asset.oracle_risk_class)}">${asset.oracle_risk_class}</span></span></div>
    </div>

    ${asset.notes || asset.price_source_notes || asset.oracle_notes || asset.registry_notes ? `
    <div class="modal-section">
      <div class="modal-section-title">Notes</div>
      ${asset.notes ? `<div class="modal-row"><span class="modal-key">General</span><span class="modal-val" style="white-space:normal">${asset.notes}</span></div>` : ""}
      ${asset.price_source_notes ? `<div class="modal-row"><span class="modal-key">Price Source</span><span class="modal-val" style="white-space:normal">${asset.price_source_notes}</span></div>` : ""}
      ${asset.oracle_notes ? `<div class="modal-row"><span class="modal-key">Oracle</span><span class="modal-val" style="white-space:normal">${asset.oracle_notes}</span></div>` : ""}
      ${asset.registry_notes ? `<div class="modal-row"><span class="modal-key">Registry</span><span class="modal-val" style="white-space:normal">${asset.registry_notes}</span></div>` : ""}
    </div>` : ""}

    <div class="modal-section">
      <div class="modal-section-title">Chain Representations (${asset.representations.length})</div>
      ${asset.representations.map(rep => `
        <div class="rep-card">
          <div class="rep-chain-row">
            <span class="rep-chain-name">${rep.chain}</span>
            ${rep.is_canonical ? `<span class="badge badge-active" style="font-size:8px">Canonical</span>` : ""}
            ${rep.is_enabled ? `<span class="badge badge-active" style="font-size:8px">Enabled</span>` : `<span class="badge badge-inactive" style="font-size:8px">Disabled</span>`}
          </div>
          <div class="rep-field">Contract: <span>${rep.contract_address}</span></div>
          <div class="rep-field">Price Feed: <span>${rep.price_feed_address || "TBD"}</span></div>
          ${rep.twap_pair ? `<div class="rep-field">TWAP Pair: <span>${rep.twap_pair}</span></div>` : ""}
          <div class="rep-field">Liquidity: <span>${rep.liquidity_status}</span></div>
          <div class="rep-field">Source Verified: <span>${rep.source_verified ? "✅ Yes" : "⚠ No"}</span></div>
        </div>
      `).join("")}
    </div>
  `;

  document.getElementById("modal-overlay").classList.add("open");
}

function closeModal(e) {
  if (e.target === document.getElementById("modal-overlay")) closeModalDirect();
}
function closeModalDirect() {
  document.getElementById("modal-overlay").classList.remove("open");
}

document.addEventListener("keydown", e => {
  if (e.key === "Escape") closeModalDirect();
});

// =====================================================
// STATUS
// =====================================================
function setStatus(state, msg) {
  const dot = document.getElementById("status-dot");
  const txt = document.getElementById("status-text");
  dot.className = `status-indicator ${state}`;
  txt.textContent = msg;
}

// =====================================================
// INIT
// =====================================================
window.addEventListener("DOMContentLoaded", () => {
  // Show file:// warning banner if opened directly from disk
  if (window.location.protocol === "file:") {
    const banner = document.getElementById("file-protocol-banner");
    if (banner) banner.style.display = "block";
  }

  // Pre-populate from cache immediately so table isn't blank while live fetch runs
  const cached = loadPriceCache();
  if (cached) {
    priceData = { ...cached.data };
    setStatus("loading", `Cached prices loaded (${cached.ageMin}min old) — fetching live data…`);
  } else {
    setStatus("loading", "Fetching live prices…");
  }

  applyFilters();  // render immediately with whatever we have
  updateSummary();
  fetchPrices();   // full multi-source pipeline runs in background
});
</script>
