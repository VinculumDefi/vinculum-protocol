<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Vinculum Protocol — Asset Registry Dashboard</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
  /* =============================================
     DESIGN SYSTEM
  ============================================= */
  :root {
    --bg-0: #080b10;
    --bg-1: #0d1117;
    --bg-2: #131920;
    --bg-3: #1a2230;
    --bg-4: #1e2a3d;
    --border: #1f2e42;
    --border-glow: #2a4060;

    --text-primary: #d4e4f7;
    --text-secondary: #7a9ab8;
    --text-muted: #3a5570;
    --text-accent: #5ab3ff;

    --accent-blue: #3b82f6;
    --accent-cyan: #22d3ee;
    --accent-gold: #f0a400;
    --accent-green: #22c55e;
    --accent-red: #ef4444;
    --accent-purple: #a78bfa;
    --accent-orange: #fb923c;

    --tier-a: #22d3ee;
    --tier-b: #a78bfa;
    --tier-c: #fb923c;

    --font-mono: 'Space Mono', monospace;
    --font-display: 'Syne', sans-serif;

    --radius: 6px;
    --radius-lg: 10px;
    --transition: 180ms ease;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg-0);
    color: var(--text-primary);
    font-family: var(--font-display);
    font-size: 14px;
    line-height: 1.5;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ---- BACKGROUND GRID ---- */
  body::before {
    content: '';
    position: fixed; inset: 0;
    background-image:
      linear-gradient(rgba(59,130,246,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(59,130,246,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  /* =============================================
     HEADER
  ============================================= */
  header {
    position: relative; z-index: 10;
    padding: 20px 32px 0;
    border-bottom: 1px solid var(--border);
    background: linear-gradient(180deg, rgba(13,17,23,0.98) 0%, rgba(8,11,16,0.95) 100%);
    backdrop-filter: blur(12px);
  }

  .header-top {
    display: flex;
    align-items: center;
    gap: 16px;
    padding-bottom: 16px;
  }

  .logo-mark {
    width: 38px; height: 38px;
    background: linear-gradient(135deg, var(--accent-blue), var(--accent-cyan));
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 16px;
    color: #fff;
    flex-shrink: 0;
    box-shadow: 0 0 20px rgba(59,130,246,0.3);
  }

  .logo-text {
    display: flex; flex-direction: column; gap: 1px;
  }

  .logo-primary {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 18px;
    letter-spacing: 0.04em;
    color: var(--text-primary);
  }

  .logo-sub {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-muted);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .header-right {
    margin-left: auto;
    display: flex; align-items: center; gap: 12px;
  }

  .price-notice {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--accent-gold);
    background: rgba(240,164,0,0.08);
    border: 1px solid rgba(240,164,0,0.2);
    padding: 6px 12px;
    border-radius: var(--radius);
    letter-spacing: 0.04em;
    max-width: 440px;
    line-height: 1.4;
  }

  .refresh-btn {
    background: var(--bg-3);
    border: 1px solid var(--border);
    color: var(--text-accent);
    padding: 8px 16px;
    border-radius: var(--radius);
    font-family: var(--font-mono);
    font-size: 11px;
    cursor: pointer;
    letter-spacing: 0.06em;
    transition: var(--transition);
    display: flex; align-items: center; gap: 6px;
  }
  .refresh-btn:hover {
    background: var(--bg-4);
    border-color: var(--accent-blue);
    color: var(--accent-cyan);
  }

  /* =============================================
     SUMMARY BAR
  ============================================= */
  .summary-bar {
    display: flex;
    gap: 0;
    border-top: 1px solid var(--border);
    margin-top: -1px;
  }

  .stat-pill {
    flex: 1;
    padding: 10px 16px;
    border-right: 1px solid var(--border);
    display: flex; flex-direction: column; gap: 2px;
  }
  .stat-pill:last-child { border-right: none; }

  .stat-label {
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--text-muted);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .stat-value {
    font-family: var(--font-mono);
    font-size: 18px;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1;
  }

  .stat-value.cyan { color: var(--accent-cyan); }
  .stat-value.blue { color: var(--accent-blue); }
  .stat-value.gold { color: var(--accent-gold); }
  .stat-value.purple { color: var(--accent-purple); }

  /* =============================================
     CONTROLS BAR
  ============================================= */
  .controls-wrap {
    position: relative; z-index: 9;
    padding: 14px 32px;
    background: rgba(8,11,16,0.95);
    border-bottom: 1px solid var(--border);
    display: flex; gap: 10px; align-items: center; flex-wrap: wrap;
  }

  .search-wrap {
    position: relative;
    flex: 1; min-width: 220px; max-width: 340px;
  }

  .search-icon {
    position: absolute; left: 10px; top: 50%; transform: translateY(-50%);
    color: var(--text-muted); font-size: 13px; pointer-events: none;
  }

  input[type="text"], select {
    background: var(--bg-2);
    border: 1px solid var(--border);
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 12px;
    border-radius: var(--radius);
    padding: 8px 10px;
    transition: var(--transition);
    outline: none;
  }

  input[type="text"] {
    padding-left: 32px;
    width: 100%;
  }

  input[type="text"]:focus, select:focus {
    border-color: var(--accent-blue);
    background: var(--bg-3);
  }

  select {
    cursor: pointer;
    padding: 8px 10px;
    min-width: 120px;
  }

  select option { background: var(--bg-1); }

  .controls-right {
    margin-left: auto;
    display: flex; gap: 8px; align-items: center;
  }

  .sort-label {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-muted);
    letter-spacing: 0.08em;
    white-space: nowrap;
  }

  /* =============================================
     MAIN CONTENT
  ============================================= */
  main {
    position: relative; z-index: 1;
    padding: 0 32px 40px;
  }

  /* =============================================
     TABLE
  ============================================= */
  .table-wrap {
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    margin-top: 20px;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    min-width: 900px;
  }

  thead tr {
    background: var(--bg-2);
    border-bottom: 1px solid var(--border);
  }

  th {
    padding: 10px 14px;
    text-align: left;
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    white-space: nowrap;
    cursor: pointer;
    user-select: none;
    transition: var(--transition);
  }
  th:hover { color: var(--text-accent); }
  th.sorted { color: var(--accent-cyan); }

  th .sort-arrow { display: inline; margin-left: 4px; opacity: 0.4; }
  th.sorted .sort-arrow { opacity: 1; }

  tbody tr {
    border-bottom: 1px solid rgba(31,46,66,0.5);
    transition: background var(--transition);
    cursor: pointer;
  }

  tbody tr:last-child { border-bottom: none; }

  tbody tr:hover {
    background: rgba(59,130,246,0.04);
  }

  td {
    padding: 11px 14px;
    vertical-align: middle;
    white-space: nowrap;
  }

  /* ---- ASSET CELL ---- */
  .asset-cell {
    display: flex; align-items: center; gap: 10px;
  }

  .asset-icon {
    width: 30px; height: 30px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--bg-3), var(--bg-4));
    border: 1px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 700;
    color: var(--text-secondary);
    flex-shrink: 0;
    overflow: hidden;
  }

  .asset-icon img { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; }

  .asset-name { font-weight: 600; font-size: 13px; color: var(--text-primary); }
  .asset-symbol {
    font-family: var(--font-mono); font-size: 10px;
    color: var(--text-secondary); display: block; margin-top: 1px;
  }

  /* ---- BADGES ---- */
  .badge {
    display: inline-flex; align-items: center;
    padding: 2px 7px;
    border-radius: 3px;
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .badge-tier-a { background: rgba(34,211,238,0.12); color: var(--tier-a); border: 1px solid rgba(34,211,238,0.2); }
  .badge-tier-b { background: rgba(167,139,250,0.12); color: var(--tier-b); border: 1px solid rgba(167,139,250,0.2); }
  .badge-tier-c { background: rgba(251,146,60,0.12); color: var(--tier-c); border: 1px solid rgba(251,146,60,0.2); }

  .badge-active { background: rgba(34,197,94,0.1); color: var(--accent-green); border: 1px solid rgba(34,197,94,0.2); }
  .badge-inactive { background: rgba(239,68,68,0.08); color: #ef4444; border: 1px solid rgba(239,68,68,0.15); }

  .badge-chainlink { background: rgba(59,130,246,0.1); color: var(--accent-blue); border: 1px solid rgba(59,130,246,0.2); }
  .badge-twap { background: rgba(240,164,0,0.1); color: var(--accent-gold); border: 1px solid rgba(240,164,0,0.2); }
  .badge-mixed { background: rgba(167,139,250,0.1); color: var(--accent-purple); border: 1px solid rgba(167,139,250,0.2); }
  .badge-tbd { background: rgba(122,154,184,0.08); color: var(--text-secondary); border: 1px solid rgba(122,154,184,0.15); }
  .badge-community { background: rgba(251,146,60,0.1); color: var(--accent-orange); border: 1px solid rgba(251,146,60,0.2); }

  /* ---- PRICE CELLS ---- */
  .price-val {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-primary);
  }

  .price-loading {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-muted);
    animation: pulse 1.4s ease-in-out infinite;
  }

  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }

  .change-pos { color: var(--accent-green); font-family: var(--font-mono); font-size: 11px; }
  .change-neg { color: var(--accent-red); font-family: var(--font-mono); font-size: 11px; }
  .change-na { color: var(--text-muted); font-family: var(--font-mono); font-size: 11px; }

  .contract-short {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-muted);
  }

  /* ---- ORACLE RISK ---- */
  .risk-low { color: var(--accent-green); font-family: var(--font-mono); font-size: 10px; }
  .risk-med { color: var(--accent-gold); font-family: var(--font-mono); font-size: 10px; }
  .risk-high { color: var(--accent-red); font-family: var(--font-mono); font-size: 10px; }
  .risk-na { color: var(--text-muted); font-family: var(--font-mono); font-size: 10px; }

  /* ---- CHAIN BADGE ---- */
  .chain-tag {
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--text-secondary);
    background: var(--bg-3);
    border: 1px solid var(--border);
    padding: 2px 6px;
    border-radius: 3px;
  }

  /* ---- ENABLED FLAG ---- */
  .dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    display: inline-block;
  }
  .dot-green { background: var(--accent-green); box-shadow: 0 0 6px rgba(34,197,94,0.5); }
  .dot-red { background: #ef4444; }
  .dot-gray { background: var(--text-muted); }

  /* =============================================
     EMPTY STATE
  ============================================= */
  .empty-state {
    padding: 60px 20px;
    text-align: center;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
  }

  /* =============================================
     MODAL
  ============================================= */
  .modal-overlay {
    display: none;
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.75);
    backdrop-filter: blur(4px);
    z-index: 1000;
    align-items: flex-start;
    justify-content: flex-end;
  }
  .modal-overlay.open { display: flex; }

  .modal-panel {
    width: 460px;
    max-width: 95vw;
    height: 100vh;
    overflow-y: auto;
    background: var(--bg-1);
    border-left: 1px solid var(--border-glow);
    padding: 28px 24px;
    animation: slideIn 240ms ease;
    position: relative;
  }

  @keyframes slideIn { from { transform: translateX(100%); opacity: 0; } to { transform: none; opacity: 1; } }

  .modal-close {
    position: absolute; top: 18px; right: 18px;
    background: var(--bg-3);
    border: 1px solid var(--border);
    color: var(--text-secondary);
    width: 30px; height: 30px;
    border-radius: var(--radius);
    cursor: pointer;
    font-size: 16px;
    display: flex; align-items: center; justify-content: center;
    transition: var(--transition);
  }
  .modal-close:hover { color: var(--text-primary); border-color: var(--accent-blue); }

  .modal-symbol-row {
    display: flex; align-items: center; gap: 14px;
    margin-bottom: 20px;
  }

  .modal-icon {
    width: 48px; height: 48px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--bg-3), var(--bg-4));
    border: 1px solid var(--border-glow);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-mono); font-size: 12px; font-weight: 700;
    color: var(--text-secondary); flex-shrink: 0;
    overflow: hidden;
  }
  .modal-icon img { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; }

  .modal-title { font-size: 22px; font-weight: 800; color: var(--text-primary); }
  .modal-ticker {
    font-family: var(--font-mono); font-size: 12px;
    color: var(--text-secondary); margin-top: 2px;
  }

  .modal-section {
    margin-bottom: 20px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--border);
  }
  .modal-section:last-child { border-bottom: none; }

  .modal-section-title {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 10px;
  }

  .modal-row {
    display: flex; align-items: flex-start;
    gap: 8px; margin-bottom: 8px;
    flex-wrap: wrap;
  }

  .modal-key {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-muted);
    min-width: 140px;
    flex-shrink: 0;
  }

  .modal-val {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-primary);
    word-break: break-all;
  }

  .rep-card {
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 10px 12px;
    margin-bottom: 8px;
  }

  .rep-chain-row {
    display: flex; align-items: center; gap: 8px; margin-bottom: 6px;
  }

  .rep-chain-name {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-accent);
    font-weight: 700;
  }

  .rep-field {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-muted);
    margin-bottom: 2px;
  }

  .rep-field span {
    color: var(--text-secondary);
  }

  /* ---- MARKET CARD in modal ---- */
  .market-card {
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 14px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 12px;
  }

  .mkt-item-label { font-family: var(--font-mono); font-size: 9px; color: var(--text-muted); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 3px; }
  .mkt-item-val { font-family: var(--font-mono); font-size: 15px; font-weight: 700; color: var(--text-primary); }

  /* =============================================
     STATUS BAR
  ============================================= */
  .status-bar {
    display: flex; align-items: center; gap: 8px;
    padding: 8px 32px;
    background: rgba(8,11,16,0.9);
    border-top: 1px solid var(--border);
    position: fixed; bottom: 0; left: 0; right: 0;
    z-index: 50;
  }

  .status-indicator {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--text-muted);
    transition: var(--transition);
  }
  .status-indicator.loading { background: var(--accent-gold); animation: pulse 1s ease-in-out infinite; }
  .status-indicator.ok { background: var(--accent-green); }
  .status-indicator.error { background: var(--accent-red); }

  .status-text {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-muted);
  }

  .status-right {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-muted);
  }

  /* =============================================
     SCROLLBAR
  ============================================= */
  ::-webkit-scrollbar { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg-0); }
  ::-webkit-scrollbar-thumb { background: var(--bg-3); border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--bg-4); }

  /* =============================================
     RESULT COUNT
  ============================================= */
  .result-count {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-muted);
    padding: 8px 32px 0;
  }


  /* =============================================
     FILE:// WARNING BANNER
  ============================================= */
  .file-protocol-banner {
    display: none; /* shown via JS when window.location.protocol === 'file:' */
    background: rgba(240,164,0,0.10);
    border-bottom: 1px solid rgba(240,164,0,0.30);
    padding: 10px 32px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--accent-gold);
    letter-spacing: 0.03em;
    line-height: 1.6;
  }
  .file-protocol-banner strong { color: #ffd060; }

  /* =============================================
     HOSTING HELP NOTE (near status bar)
  ============================================= */
  .hosting-hint {
    position: fixed; bottom: 36px; left: 0; right: 0;
    z-index: 49;
    padding: 5px 32px;
    background: rgba(8,11,16,0.92);
    border-top: 1px solid var(--border);
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--text-muted);
    letter-spacing: 0.06em;
  }
  .hosting-hint a { color: var(--text-muted); text-decoration: underline; }

  /* bump main padding to clear both bars */
  main { padding-bottom: 80px; }

  /* =============================================
     RESPONSIVE
  ============================================= */
  @media (max-width: 768px) {
    header, .controls-wrap, main, .status-bar, .result-count { padding-left: 16px; padding-right: 16px; }
    .summary-bar { flex-wrap: wrap; }
    .stat-pill { flex: 1 0 33%; }
    .price-notice { display: none; }
    .modal-panel { width: 100%; }
  }
</style>
</head>
<body>

<!-- ======================== FILE:// WARNING ======================== -->
<div class="file-protocol-banner" id="file-protocol-banner">
  <strong>⚠ Local file detected.</strong>
  This page is running as a <strong>file://</strong> URL. Live pricing API calls will be blocked by your browser's CORS policy.
  Host this file over <strong>http/https</strong> for reliable price data
  (e.g. GitHub Pages, Netlify, or <code>python -m http.server 8080</code> locally).
</div>

<!-- ======================== HEADER ======================== -->
<header>
  <div class="header-top">
    <div class="logo-mark">V</div>
    <div class="logo-text">
      <div class="logo-primary">Vinculum Protocol</div>
      <div class="logo-sub">Asset Registry // v2.6.1</div>
    </div>
    <div class="header-right">
      <div class="price-notice">
        ⚠ Displayed prices are market-data estimates for user reference.
        Final protocol pricing is determined by protocol oracle / TWAP logic.
      </div>
      <button class="refresh-btn" onclick="fetchPrices()">
        <span id="refresh-icon">↻</span> Refresh Prices
      </button>
    </div>
  </div>
  <div class="summary-bar" id="summary-bar">
    <div class="stat-pill">
      <span class="stat-label">Total Assets</span>
      <span class="stat-value" id="stat-total">—</span>
    </div>
    <div class="stat-pill">
      <span class="stat-label">Active</span>
      <span class="stat-value cyan" id="stat-active">—</span>
    </div>
    <div class="stat-pill">
      <span class="stat-label">Tier A</span>
      <span class="stat-value blue" id="stat-tier-a">—</span>
    </div>
    <div class="stat-pill">
      <span class="stat-label">Tier B</span>
