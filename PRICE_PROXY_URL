const VALID_COINGECKO_IDS = ASSETS
  .filter(a => !a.coingecko_id.startsWith("PLACEHOLDER"))
  .map(a => a.coingecko_id);


// =====================================================
// PROXY CONFIGURATION
// =====================================================
// If you have a backend proxy that fetches CoinGecko (or any source)
// server-side and returns normalized JSON, set PRICE_PROXY_URL here.
//
// Expected proxy response shape:
// {
//   "ethereum":  { "price": 3200.12, "change24h": 1.24,  "marketCap": 384000000000 },
//   "bitcoin":   { "price": 68450.00,"change24h": -0.42, "marketCap": 1340000000000 },
//   ...
// }
// Keys must match the CoinGecko IDs used in the ASSETS array above.
// Fields: price (number), change24h (number|null), marketCap (number|null)
//
// FREE PROXY OPTIONS (no backend needed):
//   • Netlify Functions:  deploy a small serverless function, set URL below.
//   • Cloudflare Workers: free tier, fetches CoinGecko server-side.
//   • GitHub Actions:     scheduled workflow writes prices.json to your repo.
//
// Leave as the placeholder string to skip proxy and use direct CoinGecko + fallbacks.
const PRICE_PROXY_URL = "https://YOUR-PROXY-URL-HERE";

/** Returns true when a real proxy URL has been configured. */
function proxyConfigured() {
  return (
    typeof PRICE_PROXY_URL === "string" &&
    PRICE_PROXY_URL.length > 0 &&
    !PRICE_PROXY_URL.includes("YOUR-PROXY-URL-HERE")
  );
}
