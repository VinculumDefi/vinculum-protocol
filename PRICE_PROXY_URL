// priceData keyed by coingecko_id.
// Each entry: { price, change24h, marketCap, price_source_resolved }
//   price_source_resolved: "CoinGecko" | "Dexscreener" | "CryptoCompare" | "Cache" | "None"
let priceData = {};
let fetchAttempted = false; // true once full fetch pipeline finishes
let sortKey = "name";
let sortDir = "asc";
let filtered = [...ASSETS];

// Build a coingecko_id → symbol lookup for fallback calls
const ID_TO_SYMBOL = {};
ASSETS.forEach(a => {
  if (!a.coingecko_id.startsWith("PLACEHOLDER")) {
    ID_TO_SYMBOL[a.coingecko_id] = a.symbol;
  }
});

// =====================================================
// LOCALSTORAGE PRICE CACHE
// =====================================================
const CACHE_KEY    = "vinculum_price_cache_v2";
const CACHE_TTL_MS = 10 * 60 * 1000; // 10 minutes — treat as fresh

/** Persist priceData + timestamp to localStorage. */
function savePriceCache(data) {
  try {
    localStorage.setItem(CACHE_KEY, JSON.stringify({ ts: Date.now(), data }));
  } catch (e) { /* quota or private mode — ignore */ }
}

/**
 * Load cached price data.
 * Returns { data, ageMin, fresh } or null if nothing cached.
 */
function loadPriceCache() {
  try {
    const raw = localStorage.getItem(CACHE_KEY);
    if (!raw) return null;
    const { ts, data } = JSON.parse(raw);
    const ageMin = Math.round((Date.now() - ts) / 60000);
    const fresh  = (Date.now() - ts) < CACHE_TTL_MS;
    return { data, ageMin, fresh };
  } catch (e) {
    return null;
  }
}

// =====================================================
// FETCH WITH TIMEOUT
// =====================================================
// FETCH WITH TIMEOUT
// NOTE: Uses Promise.race() instead of AbortController.signal.
// AbortSignal cannot be structured-cloned, which throws:
// "Failed to execute 'postMessage' on 'Window': AbortSignal object could not be cloned"
// in sandboxed/proxied fetch environments (e.g. iframe contexts).
// Promise.race() gives identical timeout behaviour with no cloning issues.
async function fetchWithTimeout(url, timeoutMs = 11000) {
  const timeout = new Promise((_, reject) =>
    setTimeout(() => reject(new Error(`Request timed out (${timeoutMs}ms)`)), timeoutMs)
  );
  return Promise.race([fetch(url), timeout]);
}

// =====================================================
// FALLBACK SOURCE 1 — DEXSCREENER
// =====================================================
// Dexscreener is a public API with no key required.
// We only call it for assets missing after CoinGecko.
async function fetchDexscreenerPrice(symbol) {
  try {
    const res = await fetchWithTimeout(
      `https://api.dexscreener.com/latest/dex/search/?q=${encodeURIComponent(symbol)}`,
      9000
    );
    if (!res.ok) return null;
    const data = await res.json();
    if (!data.pairs || data.pairs.length === 0) return null;

    // Pick the highest-liquidity pair for best price accuracy
    const best = data.pairs
      .filter(p => p.priceUsd && parseFloat(p.priceUsd) > 0)
      .sort((a, b) => (b.liquidity?.usd || 0) - (a.liquidity?.usd || 0))[0];

    if (!best) return null;
    return {
      price:     parseFloat(best.priceUsd),
      change24h: best.priceChange?.h24 != null ? parseFloat(best.priceChange.h24) : null,
      marketCap: best.fdv ?? null,
      price_source_resolved: "Dexscreener"
    };
  } catch {
    return null;
  }
}

// =====================================================
// FALLBACK SOURCE 2 — CRYPTOCOMPARE
// =====================================================
// CryptoCompare min-api requires no key for basic price calls.
// Returns price only — no 24h change or market cap available without a key.
async function fetchCryptoComparePrice(symbol) {
  try {
    const res = await fetchWithTimeout(
      `https://min-api.cryptocompare.com/data/price?fsym=${encodeURIComponent(symbol)}&tsyms=USD`,
      9000
    );
    if (!res.ok) return null;
    const data = await res.json();
    if (!data.USD || data.USD <= 0) return null;
    return {
      price:     data.USD,
      change24h: null,  // not available without API key
      marketCap: null,  // not available without API key
      price_source_resolved: "CryptoCompare"
    };
  } catch {
    return null;
  }
}

// =====================================================
// MAIN PRICE FETCH — MULTI-SOURCE PIPELINE
// =====================================================
// Priority order:
//   0. Configured proxy (PRICE_PROXY_URL) — highest priority, skips CORS issues
//   1. Direct CoinGecko batch — only if no proxy configured
//   2. Dexscreener per-asset fallback — no key required
//   3. CryptoCompare per-asset fallback — no key required
//   4. localStorage cache — always merged last
//   5. N/A — if everything above returns nothing
//
// NOTE: CoinMarketCap excluded — API key would be exposed in browser source.
// Add CMC later via backend proxy only.

async function fetchPrices() {
  document.getElementById("refresh-icon").textContent = "⟳";

  // ── Environment detection ──
  const isFileProtocol = (window.location.protocol === "file:");

  let proxyCount  = 0;
  let cgSuccess   = false;
  let cgCount     = 0;
  let cgErrorMsg  = "";
  let dexCount    = 0;
  let ccCount     = 0;
  let cacheCount  = 0;

  // ─────────────────────────────────────────────────────────
  // STAGE 0 — PROXY (primary when configured)
  // ─────────────────────────────────────────────────────────
  // Set PRICE_PROXY_URL at the top of this script to activate.
  // The proxy should accept a GET request and return JSON shaped as:
  //   { "coingecko-id": { price, change24h, marketCap }, ... }
  // This completely bypasses browser CORS restrictions.
  if (proxyConfigured()) {
    setStatus("loading", "Fetching prices via proxy…");
    try {
      const res = await fetchWithTimeout(PRICE_PROXY_URL, 12000);
      if (!res.ok) throw new Error(`Proxy HTTP ${res.status}`);
      const json = await res.json();

      // ── Normalize proxy response ──
      // Each key should be a CoinGecko ID; each value: { price, change24h, marketCap }
      for (const [id, vals] of Object.entries(json)) {
        if (vals && typeof vals.price === "number") {
          priceData[id] = {
            price:     vals.price     ?? null,
            change24h: vals.change24h ?? null,
            marketCap: vals.marketCap ?? null,
            price_source_resolved: "Proxy"
          };
          proxyCount++;
        }
      }
      if (proxyCount > 0) {
        savePriceCache(priceData);
        setStatus("ok", `Live prices: Proxy — ${proxyCount} assets — ${new Date().toLocaleTimeString()}`);
        fetchAttempted = true;
        document.getElementById("refresh-icon").textContent = "↻";
        renderTable(filtered);
        return; // proxy fully succeeded — skip all other stages
      }
      // Proxy returned empty/malformed — fall through to CoinGecko
      cgErrorMsg = "Proxy returned no usable data";
    } catch (e) {
      cgErrorMsg = `Proxy failed: ${e.message}`;
      console.warn(cgErrorMsg);
    }
  }

  // ─────────────────────────────────────────────────────────
  // STAGE 1 — COINGECKO (direct, batched)
  // ─────────────────────────────────────────────────────────
  // Skipped automatically when running from file:// to avoid noisy CORS errors.
  const batchSize = 40;
  const allIds    = [...VALID_COINGECKO_IDS];
  const batches   = [];
  for (let i = 0; i < allIds.length; i += batchSize) {
    batches.push(allIds.slice(i, i + batchSize));
  }

  if (isFileProtocol) {
    cgErrorMsg = "file:// protocol — CORS blocks direct API calls";
    console.warn("CoinGecko skipped:", cgErrorMsg);
  } else {
    setStatus("loading", `Fetching live prices — CoinGecko (${allIds.length} assets)…`);
    try {
      for (let b = 0; b < batches.length; b++) {
        const url =
          `https://api.coingecko.com/api/v3/simple/price` +
          `?ids=${batches[b].join(",")}` +
          `&vs_currencies=usd` +
          `&include_24hr_change=true` +
          `&include_market_cap=true`;

        let res;
        try {
          res = await fetchWithTimeout(url, 12000);
        } catch (fetchErr) {
          cgErrorMsg = fetchErr.message.includes("timed out")
            ? "CoinGecko timed out"
            : "CoinGecko network error (CORS / offline)";
          throw fetchErr;
        }

        if (!res.ok) {
          cgErrorMsg = `CoinGecko HTTP ${res.status} (${res.statusText})`;
          throw new Error(cgErrorMsg);
        }

        const json = await res.json();
        for (const [id, vals] of Object.entries(json)) {
          priceData[id] = {
            price:     vals.usd            ?? null,
            change24h: vals.usd_24h_change ?? null,
            marketCap: vals.usd_market_cap ?? null,
            price_source_resolved: "CoinGecko"
          };
          cgCount++;
        }
        if (b < batches.length - 1) await sleep(800); // rate-limit buffer
      }
      cgSuccess = true;
    } catch (e) {
      if (!cgErrorMsg) cgErrorMsg = e.message || "unknown error";
      console.warn("CoinGecko failed:", cgErrorMsg);
    }
  }

  // ─────────────────────────────────────────────────────────
  // STAGES 2 & 3 — DEXSCREENER + CRYPTOCOMPARE per-asset fallbacks
  // ─────────────────────────────────────────────────────────
  // Called only for assets still missing after proxy / CoinGecko.
  const missing = ASSETS.filter(a =>
    !a.coingecko_id.startsWith("PLACEHOLDER") &&
    (!priceData[a.coingecko_id] || priceData[a.coingecko_id].price === null)
  );

  if (missing.length > 0) {
    setStatus("loading",
      cgSuccess
        ? `CoinGecko: ${cgCount} — running fallbacks for ${missing.length} assets…`
        : `CoinGecko unavailable (${cgErrorMsg}) — trying Dexscreener / CryptoCompare…`
    );

    for (const asset of missing) {
      const sym  = asset.symbol;
      const cgId = asset.coingecko_id;

      const dex = await fetchDexscreenerPrice(sym);
      if (dex && dex.price > 0) {
        priceData[cgId] = dex;
        dexCount++;
        await sleep(120);
        continue;
      }

      const cc = await fetchCryptoComparePrice(sym);
      if (cc && cc.price > 0) {
        priceData[cgId] = cc;
        ccCount++;
        await sleep(120);
      }
    }
  }

  // ─────────────────────────────────────────────────────────
  // STAGE 4 — LOCALSTORAGE CACHE (final fallback)
  // ─────────────────────────────────────────────────────────
  const cached = loadPriceCache();
  if (cached) {
    for (const [id, vals] of Object.entries(cached.data)) {
      if (!priceData[id] || priceData[id].price === null) {
        priceData[id] = { ...vals, price_source_resolved: "Cache" };
        cacheCount++;
      }
    }
  }

  // Save merged result
  savePriceCache(priceData);

  // ── Build status message ──
  const totalResolved = Object.values(priceData).filter(v => v.price !== null).length;
  const parts = [];
  if (cgCount)    parts.push(`CoinGecko: ${cgCount}`);
  if (dexCount)   parts.push(`Dexscreener: ${dexCount}`);
  if (ccCount)    parts.push(`CryptoCompare: ${ccCount}`);
  if (cacheCount) parts.push(`Cache: ${cacheCount}`);

  if (totalResolved === 0 && isFileProtocol) {
    setStatus("error", "file:// detected — host over http/https for live prices");
  } else if (totalResolved === 0) {
    setStatus("error", `All sources failed — ${cgErrorMsg || "no data"} — showing N/A`);
  } else if (!cgSuccess && dexCount === 0 && ccCount === 0 && cacheCount > 0) {
    setStatus("error", `Offline mode: cached prices (${cached?.ageMin ?? "?"}min old)`);
  } else if (!cgSuccess && (dexCount > 0 || ccCount > 0)) {
    setStatus("error", `CoinGecko unavailable — fallback active (${parts.join(" / ")})`);
  } else if (dexCount > 0 || ccCount > 0) {
    setStatus("ok", `Live prices: ${parts.join(" / ")} — ${new Date().toLocaleTimeString()}`);
  } else {
    setStatus("ok", `Live prices: CoinGecko — ${cgCount} assets — ${new Date().toLocaleTimeString()}`);
  }

  fetchAttempted = true;
  document.getElementById("refresh-icon").textContent = "↻";
  renderTable(filtered);
}

function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }

// =====================================================
// FORMAT HELPERS
// =====================================================
function fmtPrice(p) {
  if (p === null || p === undefined) return "N/A";
  if (p < 0.000001) return "$" + p.toExponential(3);
  if (p < 0.01) return "$" + p.toFixed(8);
  if (p < 1) return "$" + p.toFixed(6);
  if (p < 100) return "$" + p.toFixed(4);
  return "$" + p.toLocaleString("en-US", { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

function fmtChange(c) {
  if (c === null || c === undefined) return "N/A";
  const sign = c >= 0 ? "+" : "";
  return sign + c.toFixed(2) + "%";
}

function fmtMktCap(m) {
  if (!m) return "N/A";
  if (m >= 1e12) return "$" + (m / 1e12).toFixed(2) + "T";
  if (m >= 1e9) return "$" + (m / 1e9).toFixed(2) + "B";
  if (m >= 1e6) return "$" + (m / 1e6).toFixed(2) + "M";
  return "$" + m.toLocaleString();
}

function shortAddr(addr) {
  if (!addr || addr === "TBD" || addr === "Native" || addr === "N/A") return addr;
  return addr.slice(0, 6) + "…" + addr.slice(-4);
}

function tierBadge(tier) {
  const cls = { A: "badge-tier-a", B: "badge-tier-b", C: "badge-tier-c" }[tier] || "badge-tbd";
  return `<span class="badge ${cls}">Tier ${tier}</span>`;
}

function sourceBadge(src) {
  const cls = { Chainlink: "badge-chainlink", TWAP: "badge-twap", Mixed: "badge-mixed", TBD: "badge-tbd" }[src] || "badge-tbd";
  return `<span class="badge ${cls}">${src}</span>`;
}

function riskClass(r) {
  return { Low: "risk-low", Medium: "risk-med", High: "risk-high" }[r] || "risk-na";
}

// =====================================================
// RENDER TABLE
// =====================================================
function renderTable(assets) {
  const tbody = document.getElementById("table-body");
  if (!assets.length) {
    tbody.innerHTML = `<tr><td colspan="12" class="empty-state">No assets match the current filters.</td></tr>`;
    document.getElementById("result-count").textContent = "0 assets found";
    return;
  }

  document.getElementById("result-count").textContent =
    `Showing ${assets.length} of ${ASSETS.length} assets`;

  tbody.innerHTML = assets.map((asset, idx) => {
    const pd = priceData[asset.coingecko_id] || {};
    const price = pd.price ?? null;
    const change = pd.change24h ?? null;
    const mcap = pd.marketCap ?? null;

    const isPlaceholder = asset.coingecko_id.startsWith("PLACEHOLDER");
    // After fetchAttempted, never leave a spinning/dash state — show N/A cleanly
    const priceCell = isPlaceholder
      ? `<span class="change-na">N/A</span>`
      : (price !== null
          ? `<span class="price-val">${fmtPrice(price)}</span>`
          : (fetchAttempted
              ? `<span class="change-na">N/A</span>`
              : `<span class="price-loading">—</span>`));
    const changeCell = change !== null ? `<span class="${change >= 0 ? "change-pos" : "change-neg"}">${fmtChange(change)}</span>` : `<span class="change-na">N/A</span>`;
    const mcapCell = `<span class="price-val">${fmtMktCap(mcap)}</span>`;

    const canonical = asset.representations.find(r => r.is_canonical);
    const contract = canonical?.contract_address || "TBD";

    const statusBadge = asset.active
      ? `<span class="badge badge-active">Active</span>`
      : `<span class="badge badge-inactive">Inactive</span>`;

    const enabledDot = canonical?.is_enabled
      ? `<span class="dot dot-green" title="Enabled"></span>`
      : `<span class="dot dot-gray" title="Not enabled"></span>`;

    return `<tr onclick="openModal(${idx})" data-idx="${idx}">
      <td>
        <div class="asset-cell">
          <div class="asset-icon" id="icon-${asset.symbol}">${asset.symbol.slice(0,4)}</div>
          <div>
            <div class="asset-name">${asset.name}</div>
            <span class="asset-symbol">${asset.symbol}</span>
          </div>
        </div>
      </td>
      <td>${tierBadge(asset.tier)}</td>
      <td><span class="chain-tag">${asset.category}</span></td>
      <td><span class="chain-tag">${asset.canonical_chain}</span></td>
      <td>${priceCell}</td>
      <td>${changeCell}</td>
      <td>${mcapCell}</td>
      <td>${sourceBadge(asset.price_source_type)}</td>
      <td><span class="${riskClass(asset.oracle_risk_class)}">${asset.oracle_risk_class}</span></td>
      <td>${statusBadge}</td>
      <td style="text-align:center">${enabledDot}</td>
      <td><span class="contract-short" title="${contract}">${shortAddr(contract)}</span></td>
    </tr>`;
  }).join("");

  updateSummary();
  loadCoinIcons(assets);
}

