{
  "name": "vinculum-protocol",
  "version": "1.0.0",
  "description": "Vinculum Protocol — Commitment vault protocol on Base with Axelar ITS cross-chain token",
  "scripts": {
    "test":          "npx hardhat test",
    "test:gas":      "REPORT_GAS=true npx hardhat test",
    "compile":       "npx hardhat compile",
    "clean":         "npx hardhat clean",
    "deploy:base-sepolia": "npx hardhat run deploy/00_deploy_vinculum.js --network base-sepolia",
    "deploy:base":   "npx hardhat run deploy/00_deploy_vinculum.js --network base",
    "deploy:ethereum": "npx hardhat run deploy/00_deploy_vinculum.js --network ethereum",
    "deploy:bnb":    "npx hardhat run deploy/00_deploy_vinculum.js --network bnb",
    "verify:base":   "npx hardhat verify --network base",
    "verify:ethereum": "npx hardhat verify --network ethereum",
    "coverage":      "npx hardhat coverage",
    "size":          "npx hardhat size-contracts"
  },
  "dependencies": {
    "@axelar-network/interchain-token-service": "^2.0.0",
    "@openzeppelin/contracts": "^5.0.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomiclabs/hardhat-ethers": "^2.0.0",
    "chai":          "^4.3.0",
    "dotenv":        "^16.0.0",
    "ethers":        "^6.0.0",
    "hardhat":       "^2.22.0",
    "hardhat-gas-reporter": "^1.0.0",
    "solidity-coverage": "^0.8.0"
  }
}
